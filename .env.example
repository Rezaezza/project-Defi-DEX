# Contoh variabel lingkungan untuk Hardhat localhost
LOCALHOST_URL=http://127.0.0.1:8545

# Base Sepolia RPC URL
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Arbitrum Sepolia RPC URL (Arc Testnet)
ARC_TESTNET_RPC_URL=https://sepolia-rollup.arbitrum.io:443
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io:443

# Private key untuk deployment (JANGAN bagikan kunci ini!)
# PRIVATE_KEY=your_private_key_here

# Alchemy API Keys (opsional, untuk performa RPC yang lebih baik)
# ALCHEMY_API_KEY_BASE=your_alchemy_key
# ALCHEMY_API_KEY_ARBITRUM=your_alchemy_key

# Etherscan API Keys (opsional, untuk verifikasi kontrak)
# ETHERSCAN_API_KEY=your_etherscan_key
# BASESCAN_API_KEY=your_basescan_key
# ARBISCAN_API_KEY=your_arbiscan_key
